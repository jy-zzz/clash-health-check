# Secrets for the webhook server (trojan proxy host).
# Copy to /etc/clash-health-check/webhook.env and fill in real values.
# Run: chmod 600 /etc/clash-health-check/webhook.env
#      chown root:root /etc/clash-health-check/webhook.env
# This file must NOT be committed to git.

# Shared bearer token. Must match WEBHOOK_SECRET in secrets.env on the monitor host.
WEBHOOK_TOKEN=CHANGE_ME

# Port to listen on (must match WEBHOOK_PORT in secrets.env on the monitor host).
WEBHOOK_PORT=8765
