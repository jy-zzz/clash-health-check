# Secrets for the monitor host.
# Copy to /opt/mihomo-monitor/secrets.env and fill in real values.
# Run: chmod 600 /opt/mihomo-monitor/secrets.env
# This file must NOT be committed to git.

# Bearer token for Mihomo's external controller API.
# Must match the `secret:` value in config.yaml.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
MIHOMO_API_SECRET=CHANGE_ME

# Shared secret for the webhook server on the trojan proxy host.
# Must match WEBHOOK_TOKEN in webhook.env on the trojan server.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=CHANGE_ME

# IP address or hostname of the trojan proxy server running the webhook.
TROJAN_SERVER_HOST=CHANGE_ME

# Port the webhook server listens on (must match WEBHOOK_PORT in webhook.env).
WEBHOOK_PORT=8765

# Delay threshold in milliseconds. Nodes with delay >= this value are unhealthy.
DELAY_THRESHOLD_MS=2000
